---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Project 0 - Credit for Agents",
  description = "The credit infrastructure layer for the agentic economy. Permissionless DeFi yield and credit on Solana.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#171721" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/globals.css";
</style>
