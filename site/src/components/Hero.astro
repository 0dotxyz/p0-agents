---
import LottieBackground from "./LottieBackground.tsx";
---

<section class="relative overflow-hidden pt-20">
  <!-- Mobile fallback: static SVG -->
  <img
    src="/images/backgrounds/dark/main.svg"
    alt=""
    class="absolute inset-0 -top-8 left-1/2 w-[2560px] -translate-x-1/2 lg:hidden"
    loading="eager"
  />

  <!-- Desktop: Lottie animation (React island, hydrates on visible) -->
  <LottieBackground client:visible />

  <div class="relative mx-auto max-w-5xl px-4 md:px-6">
    <div class="flex flex-col items-center pb-16 pt-16 md:pb-24 md:pt-24">
      <!-- Blurred backdrop -->
      <div
        class="absolute left-1/2 top-1/2 h-[200px] w-[320px] -translate-x-1/2 -translate-y-1/2 bg-[#171721] blur-[60px] lg:h-[280px] lg:w-[600px]"
      >
      </div>

      <!-- Content -->
      <div class="relative flex flex-col items-center space-y-6">
        <!-- Badge -->
        <div
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 font-mono text-xs uppercase text-[var(--color-muted-foreground)] backdrop-blur-sm"
        >
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-p0-purple animate-pulse"></span>
          Powered by Project 0
        </div>

        <!-- Heading -->
        <h1
          class="gradient-text py-1 text-center text-5xl font-medium leading-tight md:text-6xl lg:text-7xl"
        >
          Credit for Agents
        </h1>

        <!-- Subheading -->
        <p
          class="max-w-xl text-center text-lg text-[var(--color-muted-foreground)] md:text-xl lg:text-2xl"
        >
          The credit infrastructure layer for the agentic economy
        </p>

        <!-- Install command -->
        <div id="install" class="mt-4 w-full max-w-md">
          <div
            class="group relative flex items-center gap-3 rounded-xl border border-white/10 bg-white/[0.03] px-5 py-4 backdrop-blur-sm transition-all hover:border-white/20 hover:bg-white/[0.06]"
          >
            <span class="text-p0-purple font-mono text-sm">$</span>
            <code class="flex-1 font-mono text-sm text-white/90"
              >npx skills add 0dotxyz/skill</code
            >
            <button
              id="copy-btn"
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-white/40 transition-all hover:bg-white/10 hover:text-white/80"
              title="Copy to clipboard"
            >
              <!-- Copy icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                id="copy-icon"
              >
                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
                ></path>
              </svg>
              <!-- Check icon (hidden by default) -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                id="check-icon"
                class="hidden text-green-400"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("copy-btn");
  const copyIcon = document.getElementById("copy-icon");
  const checkIcon = document.getElementById("check-icon");

  btn?.addEventListener("click", async () => {
    await navigator.clipboard.writeText("npx skills add 0dotxyz/skill");
    copyIcon?.classList.add("hidden");
    checkIcon?.classList.remove("hidden");
    setTimeout(() => {
      copyIcon?.classList.remove("hidden");
      checkIcon?.classList.add("hidden");
    }, 2000);
  });
</script>
